# IAM Portfolio (Java) base URL — the SCIM 2.0 server we sync from.
IAM_BASE_URL=http://localhost:8080

# OAuth2 client_credentials used to obtain a Bearer token with scope scim:provision.
IAM_CLIENT_ID=demo-client
IAM_CLIENT_SECRET=demo-secret

# Local SQLite shadow store path (one row per synced user).
SCIM_SHADOW_DB_PATH=./connector.db

# Connector HTTP port (defaults to 9000).
PORT=9000
