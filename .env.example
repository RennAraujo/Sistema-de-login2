# Copy to .env (which is gitignored) and adjust as needed.

# Spring profile: local | docker | test
SPRING_PROFILES_ACTIVE=local

# Application
SERVER_PORT=8080

# PostgreSQL (matches docker-compose.yml defaults).
# Port 5433 is used to avoid clashing with any local PostgreSQL service on 5432.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=iam_portfolio
POSTGRES_USER=iam
POSTGRES_PASSWORD=iam

# JWT — generate a strong random string (>= 32 chars). Required.
JWT_SECRET=changeMeToALongRandomStringOfAtLeast32Characters!!
JWT_EXPIRATION_MS=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# 2FA
APP_2FA_ISSUER=Sistema Login Seguro
APP_2FA_APP_NAME=LoginSeguro
