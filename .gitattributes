# Auto-detect text files and normalize line endings to LF on commit.
* text=auto eol=lf

# Source code: always LF
*.java       text eol=lf
*.kt         text eol=lf
*.py         text eol=lf
*.sh         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.xml        text eol=lf
*.sql        text eol=lf
*.properties text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.md         text eol=lf
*.toml       text eol=lf
*.ini        text eol=lf
*.conf       text eol=lf
Dockerfile   text eol=lf

# Windows-only scripts: keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary: never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.jar   binary
*.zip   binary
*.tar   binary
*.gz    binary
*.jks   binary
*.p12   binary
